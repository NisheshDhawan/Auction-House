# =============================================================
# Auction House — Environment Variables Template
# Copy this to .env and fill in your actual values.
# NEVER commit the actual .env file to Git.
# Set these as environment variables on your hosting platform.
# =============================================================

# --- Supabase ---
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# --- API URLs (update before deploying) ---
# Frontend: the URL where your Express backend is deployed
VITE_API_URL=https://your-backend.onrender.com
# Backend: the URL where your Vite frontend is deployed
CLIENT_URL=https://your-frontend.vercel.app
PORT=3000

# --- JWT ---
# Generate a strong secret: node -e "require('crypto').randomBytes(32).toString('hex')"
JWT_SECRET=replace_with_a_strong_random_secret

# --- SMTP (Email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME=Auction House

# --- Razorpay ---
# Use rzp_test_ keys for testing, rzp_live_ keys for production
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
VITE_RAZORPAY_KEY_ID=rzp_live_your_key_id
